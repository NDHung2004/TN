<nav class="navbar navbar-expand-lg navbar-dark <%= (typeof generalSetting !== 'undefined' && generalSetting.navColor) ? generalSetting.navColor : 'bg-dark' %> sticky-top">
    <div class="container-fluid">
        
        <a class="navbar-brand fw-bold" href="/">
            <% if(typeof generalSetting !== 'undefined' && generalSetting.logoUrl) { %>
                <img src="<%= generalSetting.logoUrl %>" alt="Logo" height="35" class="d-inline-block align-text-top me-2" style="border-radius: 5px;">
                <span class="d-none d-md-inline"><%= generalSetting.siteTitle || 'Quán Ăn Việt' %></span>
            <% } else { %>
                <%= (typeof generalSetting !== 'undefined' && generalSetting.siteTitle) ? generalSetting.siteTitle : 'Quán Ăn Việt' %>
            <% } %>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/campgrounds">Khám phá Quán</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/campgrounds/new">Đăng Quán mới</a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-center">
                
                <% if(!currentUser) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Đăng nhập</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3 ms-2" href="/register">Đăng ký</a>
                    </li>
                <% } else { %>
                    
                    <% if(currentUser.role === 'admin') { %>
                        <li class="nav-item me-2">
                            <a class="nav-link text-warning fw-bold border border-warning rounded px-2" href="/admin">
                                <i class="fas fa-user-shield"></i> QUẢN TRỊ
                            </a>
                        </li>
                    <% } else if(currentUser.role === 'moderator') { %>
                        <li class="nav-item me-2">
                            <a class="nav-link text-info fw-bold border border-info rounded px-2" href="/admin/campgrounds">
                                <i class="fas fa-tasks"></i> DUYỆT BÀI
                            </a>
                        </li>
                    <% } %>

                    <li class="nav-item dropdown ms-2">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                            <div class="bg-secondary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 30px; height: 30px;">
                                <%= currentUser.username[0].toUpperCase() %>
                            </div>
                            <%= currentUser.username %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <a class="dropdown-item" href="/my-restaurants">
                                    <i class="fas fa-store me-2 text-primary"></i> Quán của tôi
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/favorites">
                                    <i class="fas fa-heart me-2 text-danger"></i> Đã thích
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="/logout">
                                    <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>