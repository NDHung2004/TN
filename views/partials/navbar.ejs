    <!-- Mobile Menu -->
    <div class="md:hidden hidden bg-white dark:bg-dark-bg border-b border-gray-100 dark:border-gray-800"
        id="mobile-menu">
        <div class="px-2 pt-2 pb-3 space-y-1">
