            <button id="navFindNearbyBtnMobile"
                class="w-full text-left block px-3 py-2 rounded-md text-base font-medium text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800"><i
                    class="fas fa-location-arrow text-primary-500 mr-2 w-5"></i> Tìm Quán Ở Gần</button>

            <div class="h-px bg-gray-100 dark:bg-gray-800 my-2"></div>

            <% if(!currentUser) { %>
                <a href="/login"
