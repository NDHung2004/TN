<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quán Ăn Việt</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous" />
    <link rel="stylesheet" href="/stylesheets/home.css" />
  </head>

  <body class="d-flex text-center text-white bg-dark">
    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
      <header class="mb-auto">
        <div class="d-flex justify-content-between align-items-center">
          <h3 class="mb-0">Quán Ăn Việt</h3>

          <nav class="nav nav-masthead">
            <a class="nav-link active" aria-current="page" href="#">Trang chủ</a>
            <a class="nav-link" href="/campgrounds">Quán ăn</a>
            <% if (!currentUser) {%>
            <a class="nav-link" href="/login">Đăng nhập</a>
            <a class="nav-link" href="/register">Đăng ký</a>
            <% } else { %>
            <a class="nav-link" href="/logout">Đăng xuất</a>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="px-3">
        <h1>Quán Ăn Việt</h1>
        <p class="lead">
          Chào mừng bạn đến với hệ thống đánh giá quán ăn! <br />
          Khám phá nhiều quán ăn hấp dẫn xung quanh bạn. <br />
          Hãy chia sẻ trải nghiệm và đánh giá của bạn với mọi người.
        </p>
        <a
          href="/campgrounds"
          class="btn btn-lg btn-secondary fw-bold border-white bg-white">
          Xem danh sách quán ăn
        </a>
      </main>

      <footer class="mt-auto text-white-50">
        <p>&copy; 2020 Quán Ăn Việt.</p>
      </footer>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bs-custom-file-input/dist/bs-custom-file-input.min.js"></script>
    <script src="/javascript/validateForms.js"></script>
  </body>
</html>
