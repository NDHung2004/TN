<% layout('layouts/boilerplate') %>

<div class="flex min-h-screen bg-gray-50 dark:bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden md:block sticky top-0 h-screen">
        <%- include('../partials/adminSidebar') %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-6 md:p-10 max-w-7xl mx-auto">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight" data-aos="fade-right">Quản lý Bài Đăng</h1>
            <div class="flex items-center gap-3">
                <button type="button" id="btnExportExcel" class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-xl shadow-sm transition-colors" data-aos="fade-left">
                    <i class="fas fa-file-excel mr-2"></i> Xuất Excel
                </button>
                <a href="/restaurants/new" target="_blank" class="inline-flex items-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-xl shadow-sm transition-colors" data-aos="fade-left" data-aos-delay="100">
                    <i class="fas fa-plus mr-2"></i> Thêm quán ăn mới
                </a>
            </div>
        </div>

        <!-- Tabs -->
        <div class="border-b border-gray-200 dark:border-gray-800 mb-6" data-aos="fade-up" data-aos-delay="0">
            <nav class="-mb-px flex space-x-6 overflow-x-auto custom-scrollbar">
                <a href="/admin/restaurants" class="<%= !filter ? 'border-primary-500 text-primary-600 dark:text-primary-400' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors">
                    Tất cả
                </a>
                <a href="/admin/restaurants?filter=pending" class="<%= filter === 'pending' ? 'border-primary-500 text-primary-600 dark:text-primary-400' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors flex items-center">
                    Chờ duyệt 
                    <span class="ml-2 bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 py-0.5 px-2 rounded-full text-xs">!</span>
                </a>
                <a href="/admin/restaurants?filter=approved" class="<%= filter === 'approved' ? 'border-primary-500 text-primary-600 dark:text-primary-400' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors">
                    Đã duyệt
                </a>
            </nav>
        </div>

        <!-- Card Container -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800" data-aos="fade-up" data-aos-delay="100">
            
            <!-- Filter Bar -->
            <div class="p-6 border-b border-gray-100 dark:border-gray-800">
                <form action="/admin/restaurants" method="GET" class="flex flex-col sm:flex-row gap-3">
                    <% if(filter) { %>
                        <input type="hidden" name="filter" value="<%= filter %>">
                    <% } %>
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400"></i>
                        </div>
                        <input type="text" name="search" class="block w-full pl-10 pr-3 py-2 border border-gray-200 dark:border-gray-700 rounded-xl leading-5 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm transition-colors" placeholder="Tìm tên quán hoặc địa điểm..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    </div>
                    <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-gray-900 hover:bg-gray-800 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 transition-colors shadow-sm whitespace-nowrap">
                        <i class="fas fa-search mr-2"></i> Tìm kiếm
                    </button>
                    <% if(typeof search !== 'undefined' && search) { %>
                        <a href="/admin/restaurants<%= filter ? `?filter=${filter}` : '' %>" class="inline-flex items-center justify-center px-4 py-2 border border-gray-200 dark:border-gray-700 text-sm font-medium rounded-xl text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shadow-sm whitespace-nowrap">
                            <i class="fas fa-times mr-2"></i> Xóa lọc
                        </a>
                    <% } %>
                </form>
            </div>

            <!-- Table & Bulk Form -->
            <!-- Hidden Bulk Form -->
            <form action="/admin/restaurants/bulk?_method=PATCH" method="POST" id="bulkForm" class="hidden">
                <input type="hidden" name="action" id="bulkActionInput" value="">
                <div id="bulkIdsContainer"></div>
            </form>

            <!-- Table Container -->
            <div>
                <!-- Bulk Actions Toolbar -->
                <div class="px-6 py-3 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <span class="text-sm text-gray-500 dark:text-gray-400 font-medium">Hành động hàng loạt:</span>
                        <button type="button" class="btn-bulk-action px-3 py-1.5 bg-emerald-100 text-emerald-700 hover:bg-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 rounded-lg text-sm font-medium transition-colors cursor-pointer" data-action="approve" data-title="Duyệt các quán ăn đã chọn?" data-text="Các quán ăn này sẽ được hiển thị công khai trên hệ thống." data-icon="question" data-confirm="Đồng ý Duyệt" data-color="#10B981">
                            <i class="fas fa-check mr-1"></i> Duyệt
                        </button>
                        <button type="button" class="btn-bulk-action px-3 py-1.5 bg-amber-100 text-amber-700 hover:bg-amber-200 dark:bg-amber-900/30 dark:text-amber-400 rounded-lg text-sm font-medium transition-colors cursor-pointer" data-action="reject" data-title="Từ chối các quán ăn đã chọn?" data-text="Các quán ăn này sẽ bị đánh dấu từ chối." data-icon="warning" data-confirm="Từ chối" data-color="#F59E0B">
                            <i class="fas fa-times mr-1"></i> Từ chối
                        </button>
                        <button type="button" class="btn-bulk-action px-3 py-1.5 bg-rose-100 text-rose-700 hover:bg-rose-200 dark:bg-rose-900/30 dark:text-rose-400 rounded-lg text-sm font-medium transition-colors cursor-pointer" data-action="delete" data-title="Xóa các quán ăn đã chọn?" data-text="Hành động này không thể hoàn tác. Toàn bộ dữ liệu liên quan sẽ bị xóa vĩnh viễn!" data-icon="error" data-confirm="Xóa Vĩnh Viễn" data-color="#EF4444">
                            <i class="fas fa-trash-alt mr-1"></i> Xóa
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
                    <thead class="bg-gray-50 dark:bg-gray-800/50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-10">
                                <input type="checkbox" id="selectAll" class="rounded border-gray-300 text-primary-600 shadow-sm focus:border-primary-300 focus:ring focus:ring-primary-200 focus:ring-opacity-50 dark:bg-gray-700 dark:border-gray-600">
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Hình ảnh</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tên quán</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Người đăng</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trạng thái</th>
                            <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Nổi bật</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-dark-card divide-y divide-gray-100 dark:divide-gray-800">
                        <% for(let camp of restaurants) { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input type="checkbox" name="restaurantIds" value="<%= camp._id %>" class="rowCheckbox rounded border-gray-300 text-primary-600 shadow-sm focus:border-primary-300 focus:ring focus:ring-primary-200 focus:ring-opacity-50 dark:bg-gray-700 dark:border-gray-600">
                                </td>
                                <!-- Image -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if(camp.images.length) { %>
                                        <img src="<%= camp.images[0].url %>" alt="" class="h-12 w-12 rounded-lg object-cover shadow-sm">
                                    <% } else { %>
                                        <div class="h-12 w-12 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                                            <i class="fas fa-image text-gray-400"></i>
                                        </div>
                                    <% } %>
                                </td>

                                <!-- Title & Date -->
                                <td class="px-6 py-4">
                                    <div class="text-sm font-bold text-gray-900 dark:text-white">
                                        <a href="/restaurants/<%= camp._id %>" target="_blank" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors group">
                                            <%= camp.title %>
                                            <i class="fas fa-external-link-alt text-[10px] ml-1 opacity-0 group-hover:opacity-100 transition-opacity"></i>
                                        </a>
                                    </div>
                                    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                                        <%= new Date(camp.createdAt).toLocaleDateString('vi-VN') %>
                                    </div>
                                </td>

                                <!-- Author -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="h-6 w-6 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-600 dark:text-gray-300 mr-2">
                                            <%= camp.author ? camp.author.username[0].toUpperCase() : '?' %>
                                        </div>
                                        <span class="text-sm text-gray-700 dark:text-gray-300"><%= camp.author ? camp.author.username : 'Unknown' %></span>
                                    </div>
                                </td>

                                <!-- Status -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if(camp.status === 'pending') { %>
                                        <div class="flex items-center gap-2">
                                            <form action="/admin/restaurants/<%= camp._id %>/status?_method=PATCH" method="POST" class="inline-block form-single-action" data-title="Duyệt bài đăng" data-text="Quán ăn '<%= camp.title %>' sẽ được phê duyệt và hiển thị công khai." data-icon="question" data-confirm="Đồng ý Duyệt" data-color="#10B981">
                                                <input type="hidden" name="status" value="approved">
                                                <button type="submit" class="inline-flex items-center px-2.5 py-1.5 border border-transparent text-xs font-medium rounded-lg text-emerald-700 bg-emerald-100 hover:bg-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 dark:hover:bg-emerald-900/50 transition-colors shadow-sm" title="Duyệt bài đăng">
                                                    <i class="fas fa-check mr-1"></i> Duyệt
                                                </button>
                                            </form>
                                            <form action="/admin/restaurants/<%= camp._id %>/status?_method=PATCH" method="POST" class="inline-block form-single-action" data-title="Từ chối bài đăng" data-text="Bạn muốn từ chối quán ăn '<%= camp.title %>'?" data-icon="warning" data-confirm="Từ chối" data-color="#F59E0B">
                                                <input type="hidden" name="status" value="rejected">
                                                <button type="submit" class="inline-flex items-center px-2.5 py-1.5 border border-transparent text-xs font-medium rounded-lg text-rose-700 bg-rose-100 hover:bg-rose-200 dark:bg-rose-900/30 dark:text-rose-400 dark:hover:bg-rose-900/50 transition-colors shadow-sm" title="Từ chối bài đăng">
                                                    <i class="fas fa-times mr-1"></i> Không duyệt
                                                </button>
                                            </form>
                                        </div>
                                    <% } else if(camp.status === 'approved') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800/50">
                                            <i class="fas fa-check-circle mr-1.5"></i> Đã duyệt
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-rose-50 text-rose-700 border border-rose-200 dark:bg-rose-900/20 dark:text-rose-400 dark:border-rose-800/50">
                                            <i class="fas fa-times-circle mr-1.5"></i> Bị từ chối
                                        </span>
                                    <% } %>
                                </td>

                                <!-- Featured -->
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <form action="/admin/restaurants/<%= camp._id %>/featured?_method=PATCH" method="POST">
                                        <button type="submit" class="p-2 rounded-full transition-colors <%= camp.isFeatured ? 'text-amber-500 bg-amber-50 hover:bg-amber-100 dark:bg-amber-900/30 dark:hover:bg-amber-900/50' : 'text-gray-400 bg-gray-50 hover:bg-gray-100 dark:text-gray-500 dark:bg-gray-800 dark:hover:bg-gray-700' %>" title="<%= camp.isFeatured ? 'Bỏ ghim' : 'Ghim lên trang chủ' %>">
                                            <i class="fas fa-star"></i>
                                        </button>
                                    </form>
                                </td>

                                <!-- Actions -->
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/restaurants/<%= camp._id %>/edit" target="_blank" class="p-2 text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-900/30 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/restaurants/<%= camp._id %>?_method=DELETE" method="POST" class="inline-block form-single-action" data-title="Xóa quán ăn?" data-text="Bạn chắc chắn muốn xóa quán ăn '<%= camp.title %>'? Hành động này không thể hoàn tác!" data-icon="error" data-confirm="Xóa Vĩnh Viễn" data-color="#EF4444">
                                            <button type="submit" class="p-2 text-rose-600 hover:text-rose-900 dark:text-rose-400 dark:hover:text-rose-300 bg-rose-50 hover:bg-rose-100 dark:bg-rose-900/30 dark:hover:bg-rose-900/50 rounded-lg transition-colors" title="Xóa bài">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                        
                        <% if(restaurants.length === 0) { %>
                            <tr>
                                <td colspan="7" class="px-6 py-10 text-center text-gray-500 dark:text-gray-400">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fas fa-inbox text-4xl mb-3 text-gray-300 dark:text-gray-600"></i>
                                        <p>Không tìm thấy quán ăn nào.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            </div>

            <!-- Pagination -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-800 flex items-center justify-between">
                    <div class="flex-1 flex justify-center">
                        <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                            <a href="<%= currentPage === 1 ? '#' : `/admin/restaurants?page=${currentPage - 1}${typeof filter !== 'undefined' && filter ? '&filter=' + filter : ''}${typeof search !== 'undefined' && search ? '&search=' + search : ''}` %>" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium <%= currentPage === 1 ? 'text-gray-300 dark:text-gray-600 cursor-not-allowed' : 'text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                                <span class="sr-only">Previous</span>
                                <i class="fas fa-chevron-left"></i>
                            </a>
                            
                            <% 
                               let startPage = Math.max(1, currentPage - 2);
                               let endPage = Math.min(totalPages, currentPage + 2);
                            %>

                            <% if (startPage > 1) { %>
                                <a href="/admin/restaurants?page=1<%= typeof filter !== 'undefined' && filter ? '&filter=' + filter : '' %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">1</a>
                                <% if (startPage > 2) { %>
                                    <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300">...</span>
                                <% } %>
                            <% } %>

                            <% for(let i = startPage; i <= endPage; i++) { %>
                                <a href="/admin/restaurants?page=<%= i %><%= typeof filter !== 'undefined' && filter ? '&filter=' + filter : '' %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="relative inline-flex items-center px-4 py-2 border <%= currentPage === i ? 'z-10 bg-primary-50 dark:bg-primary-900/30 border-primary-500 text-primary-600 dark:text-primary-400' : 'border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %> text-sm font-medium">
                                    <%= i %>
                                </a>
                            <% } %>

                            <% if (endPage < totalPages) { %>
                                <% if (endPage < totalPages - 1) { %>
                                    <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300">...</span>
                                <% } %>
                                <a href="/admin/restaurants?page=<%= totalPages %><%= typeof filter !== 'undefined' && filter ? '&filter=' + filter : '' %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"><%= totalPages %></a>
                            <% } %>

                            <a href="<%= currentPage === totalPages ? '#' : `/admin/restaurants?page=${currentPage + 1}${typeof filter !== 'undefined' && filter ? '&filter=' + filter : ''}${typeof search !== 'undefined' && search ? '&search=' + search : ''}` %>" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium <%= currentPage === totalPages ? 'text-gray-300 dark:text-gray-600 cursor-not-allowed' : 'text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                                <span class="sr-only">Next</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </nav>
                    </div>
                </div>
            <% } %>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const selectAll = document.getElementById('selectAll');
        const rowCheckboxes = document.querySelectorAll('.rowCheckbox');

        if(selectAll) {
            selectAll.addEventListener('change', (e) => {
                rowCheckboxes.forEach(cb => {
                    cb.checked = e.target.checked;
                });
            });
        }
        
        rowCheckboxes.forEach(cb => {
            cb.addEventListener('change', () => {
                const allChecked = Array.from(rowCheckboxes).every(c => c.checked);
                const someChecked = Array.from(rowCheckboxes).some(c => c.checked);
                selectAll.checked = allChecked;
                selectAll.indeterminate = someChecked && !allChecked;
            });
        });

        // Xử lý SweetAlert2 cho Single Actions
        const singleForms = document.querySelectorAll('.form-single-action');
        singleForms.forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const title = this.getAttribute('data-title');
                const text = this.getAttribute('data-text');
                const icon = this.getAttribute('data-icon');
                const confirmBtnText = this.getAttribute('data-confirm');
                const confirmColor = this.getAttribute('data-color');

                Swal.fire({
                    title: title,
                    text: text,
                    icon: icon,
                    showCancelButton: true,
                    confirmButtonColor: confirmColor,
                    cancelButtonColor: '#6B7280',
                    confirmButtonText: confirmBtnText,
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        this.submit();
                    }
                });
            });
        });

        // Xử lý SweetAlert2 cho Bulk Actions
        const bulkBtns = document.querySelectorAll('.btn-bulk-action');
        const bulkForm = document.getElementById('bulkForm');
        const bulkActionInput = document.getElementById('bulkActionInput');

        bulkBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const selectedCount = document.querySelectorAll('.rowCheckbox:checked').length;
                if (selectedCount === 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Chưa chọn quán ăn nào',
                        text: 'Vui lòng chọn ít nhất 1 quán ăn để thực hiện hành động này.',
                        confirmButtonColor: '#3B82F6'
                    });
                    return;
                }

                const action = this.getAttribute('data-action');
                const title = this.getAttribute('data-title');
                const text = this.getAttribute('data-text');
                const icon = this.getAttribute('data-icon');
                const confirmBtnText = this.getAttribute('data-confirm');
                const confirmColor = this.getAttribute('data-color');

                Swal.fire({
                    title: title,
                    text: `Bạn đang chọn ${selectedCount} quán ăn. ${text}`,
                    icon: icon,
                    showCancelButton: true,
                    confirmButtonColor: confirmColor,
                    cancelButtonColor: '#6B7280',
                    confirmButtonText: confirmBtnText,
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        bulkActionInput.value = action;
                        const container = document.getElementById('bulkIdsContainer');
                        container.innerHTML = '';
                        document.querySelectorAll('.rowCheckbox:checked').forEach(cb => {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.name = 'restaurantIds';
                            input.value = cb.value;
                            container.appendChild(input);
                        });
                        bulkForm.submit();
                    }
                });
            });
        });
        
        // --- XUẤT EXCEL CÓ TÙY CHỌN ---
        document.getElementById('btnExportExcel').addEventListener('click', () => {
            Swal.fire({
                title: 'Tùy chọn Xuất Excel',
                customClass: {
                    popup: 'rounded-3xl shadow-2xl border border-gray-100 dark:border-gray-800 dark:bg-gray-900',
                    title: 'text-2xl font-extrabold text-gray-900 dark:text-white pt-4',
                    confirmButton: 'px-6 py-2.5 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 transition-colors shadow-sm',
                    cancelButton: 'px-6 py-2.5 bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 font-medium rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors ml-3'
                },
                buttonsStyling: false,
                html: `
                    <div class="text-left mt-4 px-2">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Trạng thái duyệt</label>
                        <select id="swal-status" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none mb-5 transition-colors">
                            <option value="all">Tất cả</option>
                            <option value="approved">Đã duyệt</option>
                            <option value="pending">Chờ duyệt</option>
                            <option value="rejected">Bị từ chối</option>
                        </select>

                        <div class="flex gap-4">
                            <div class="w-1/2">
                                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Từ trang</label>
                                <input id="swal-page-from" type="number" min="1" value="1" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="1">
                            </div>
                            <div class="w-1/2">
                                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Đến trang</label>
                                <input id="swal-page-to" type="number" min="1" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="Tất cả">
                            </div>
                        </div>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: '<i class="fas fa-file-download mr-1"></i> Tải xuống',
                cancelButtonText: 'Hủy',
                preConfirm: () => {
                    return {
                        status: document.getElementById('swal-status').value,
                        pageFrom: document.getElementById('swal-page-from').value,
                        pageTo: document.getElementById('swal-page-to').value
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const v = result.value;
                    let url = '/admin/restaurants/export?status=' + v.status;
                    if(v.pageFrom) url += '&pageFrom=' + v.pageFrom;
                    if(v.pageTo) url += '&pageTo=' + v.pageTo;
                    window.location.href = url;
                }
            });
        });
    });
</script>