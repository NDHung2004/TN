<% layout('layouts/boilerplate') %>

<div class="flex min-h-screen bg-gray-50 dark:bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden md:block sticky top-0 h-screen">
        <%- include('../partials/adminSidebar') %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-6 md:p-10 max-w-7xl mx-auto">
        <div class="mb-8" data-aos="fade-right">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight flex items-center">
                <i class="fas fa-cogs text-gray-500 mr-3"></i> Cấu hình Giao diện
            </h1>
        </div>

        <form action="/admin/settings/general?_method=PUT" method="POST" class="space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                
                <!-- Card 1: Header & Navbar -->
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden flex flex-col" data-aos="fade-up" data-aos-delay="0">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-4">
                        <h5 class="text-white font-bold m-0 flex items-center">
                            <i class="fas fa-desktop mr-2 text-blue-200"></i> Header & Navbar
                        </h5>
                    </div>
                    
                    <div class="p-6 flex-1 space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Tên Website</label>
                            <input type="text" name="setting[siteTitle]" value="<%= setting.siteTitle %>" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors">
                        </div>
                        
                        <hr class="border-gray-100 dark:border-gray-800">
                        
                        <div>
                            <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Hotline (Trên Menu)</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-phone-alt text-gray-400"></i>
                                </div>
                                <input type="text" name="setting[hotline]" value="<%= setting.hotline %>" placeholder="VD: 1900 1000" class="block w-full pl-10 pr-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors">
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Màu nền Navbar</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-palette text-gray-400"></i>
                                </div>
                                <select name="setting[navColor]" class="block w-full pl-10 pr-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors appearance-none">
                                    <option value="bg-dark" <%= setting.navColor === 'bg-dark' ? 'selected' : '' %>>Màu Đen (Dark)</option>
                                    <option value="bg-primary" <%= setting.navColor === 'bg-primary' ? 'selected' : '' %>>Màu Xanh (Blue)</option>
                                    <option value="bg-danger" <%= setting.navColor === 'bg-danger' ? 'selected' : '' %>>Màu Đỏ (Red)</option>
                                    <option value="bg-success" <%= setting.navColor === 'bg-success' ? 'selected' : '' %>>Màu Xanh lá (Green)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 2: Footer -->
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden flex flex-col" data-aos="fade-up" data-aos-delay="100">
                    <div class="bg-gray-900 dark:bg-gray-800 px-6 py-4">
                        <h5 class="text-white font-bold m-0 flex items-center">
                            <i class="fas fa-shoe-prints mr-2 text-gray-400"></i> Footer
                        </h5>
                    </div>
                    
                    <div class="p-6 flex-1 space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Nội dung giới thiệu</label>
                            <textarea name="setting[footer][content]" rows="3" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-500 focus:border-transparent transition-colors resize-none"><%= setting.footer.content %></textarea>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Dòng bản quyền (Copyright)</label>
                            <input type="text" name="setting[footer][copyright]" value="<%= setting.footer.copyright %>" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-500 focus:border-transparent transition-colors">
                        </div>
                        
                        <div>
                            <h6 class="text-sm font-bold text-primary-600 dark:text-primary-400 mb-3 border-b border-gray-100 dark:border-gray-800 pb-2">Thông tin liên hệ</h6>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Email</label>
                                    <input type="email" name="setting[footer][email]" value="<%= setting.footer.email %>" class="block w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors">
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Địa chỉ</label>
                                    <input type="text" name="setting[footer][address]" value="<%= setting.footer.address %>" class="block w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors">
                                </div>
                            </div>
                        </div>

                        <div>
                            <h6 class="text-sm font-bold text-primary-600 dark:text-primary-400 mb-3 border-b border-gray-100 dark:border-gray-800 pb-2">Mạng xã hội</h6>
                            <div class="space-y-3">
                                <div class="flex">
                                    <span class="inline-flex items-center px-4 rounded-l-lg border border-r-0 border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-500">
                                        <i class="fab fa-facebook text-blue-600"></i>
                                    </span>
                                    <input type="url" name="setting[footer][socials][facebook]" value="<%= setting.footer.socials.facebook %>" placeholder="Link Facebook..." class="flex-1 block w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-r-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors">
                                </div>
                                <div class="flex">
                                    <span class="inline-flex items-center px-4 rounded-l-lg border border-r-0 border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-500">
                                        <i class="fab fa-youtube text-red-600"></i>
                                    </span>
                                    <input type="url" name="setting[footer][socials][youtube]" value="<%= setting.footer.socials.youtube %>" placeholder="Link Youtube..." class="flex-1 block w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-r-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-center mt-8 mb-12" data-aos="fade-up" data-aos-delay="200">
                <button type="submit" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-bold rounded-xl text-white bg-emerald-600 hover:bg-emerald-700 shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-200 w-full md:w-1/2 lg:w-1/3">
                    <i class="fas fa-save mr-3 text-emerald-200"></i> LƯU CẤU HÌNH
                </button>
            </div>
        </form>

    </div>
</div>