<% layout('layouts/boilerplate') %>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 p-0">
            <%- include('../partials/adminSidebar') %>
        </div>

        <div class="col-md-10 p-4">
            <h1>Quản lý Danh mục (Loại hình quán)</h1>
            <p class="text-muted">Các danh mục này sẽ hiển thị trong ô chọn khi đăng quán mới.</p>
            <hr>

            <div class="row mt-4">
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-plus-circle"></i> Thêm Danh mục</h5>
                        </div>
                        <div class="card-body">
                            <form action="/admin/categories" method="POST">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tên loại hình</label>
                                    <input type="text" class="form-control" name="name" placeholder="VD: Buffet, Lẩu nướng..." required>
                                </div>
                                <div class="d-grid">
                                    <button class="btn btn-success">Thêm mới</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card shadow">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0"><i class="fas fa-list"></i> Danh sách hiện có (<%= categories.length %>)</h5>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                <% if(categories.length === 0) { %>
                                    <li class="list-group-item text-center text-muted py-4">Chưa có danh mục nào. Hãy thêm mới!</li>
                                <% } %>

                                <% for(let cat of categories) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span class="fw-bold fs-5"><%= cat.name %></span>
                                    
                                    <form action="/admin/categories/<%= cat._id %>?_method=DELETE" method="POST" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục [<%= cat.name %>] không?');">
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </button>
                                    </form>
                                </li>
                                <% } %>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>