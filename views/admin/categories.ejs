<% layout('layouts/boilerplate') %>

<div class="flex min-h-screen bg-gray-50 dark:bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden md:block sticky top-0 h-screen">
        <%- include('../partials/adminSidebar') %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-6 md:p-10 max-w-7xl mx-auto">
        <div class="mb-8" data-aos="fade-right">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight flex items-center">
                <i class="fas fa-tags text-primary-500 mr-3"></i> Quản lý Danh mục
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">Các danh mục này sẽ hiển thị trong ô chọn khi người dùng đăng bài viết mới.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Left Column: Add Category Form -->
            <div class="lg:col-span-1" data-aos="fade-up" data-aos-delay="0">
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden sticky top-24">
                    <div class="bg-gradient-to-r from-primary-600 to-primary-800 px-6 py-4">
                        <h5 class="text-white font-bold m-0 flex items-center">
                            <i class="fas fa-plus-circle mr-2 text-primary-100"></i> Thêm Danh mục
                        </h5>
                    </div>
                    <div class="p-6">
                        <form action="/admin/categories" method="POST" class="space-y-4">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Tên loại hình</label>
                                <input type="text" name="name" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors" placeholder="VD: Buffet, Lẩu nướng..." required>
                            </div>
                            <button type="submit" class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-700 transition-colors">
                                <i class="fas fa-save mr-2"></i> Lưu danh mục
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Category List -->
            <div class="lg:col-span-2" data-aos="fade-up" data-aos-delay="100">
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden">
                    <div class="bg-gray-900 dark:bg-gray-800 px-6 py-4 flex justify-between items-center">
                        <h5 class="text-white font-bold m-0 flex items-center">
                            <i class="fas fa-list mr-2 text-gray-400"></i> Danh sách hiện có
                        </h5>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-700 text-gray-100">
                            <%= categories.length %> danh mục
                        </span>
                    </div>
                    
                    <ul class="divide-y divide-gray-100 dark:divide-gray-800">
                        <% if(categories.length === 0) { %>
                            <li class="px-6 py-10 text-center text-gray-500 dark:text-gray-400">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-tags text-4xl mb-3 text-gray-300 dark:text-gray-600"></i>
                                    <p>Chưa có danh mục nào. Hãy thêm danh mục đầu tiên!</p>
                                </div>
                            </li>
                        <% } %>

                        <% for(let cat of categories) { %>
                            <li class="px-6 py-4 flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
                                <div class="flex items-center">
                                    <div class="w-10 h-10 rounded-xl bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 flex items-center justify-center font-bold mr-4">
                                        <%= cat.name[0].toUpperCase() %>
                                    </div>
                                    <span class="font-bold text-gray-900 dark:text-white text-lg"><%= cat.name %></span>
                                </div>
                                
                                <form action="/admin/categories/<%= cat._id %>?_method=DELETE" method="POST" class="inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục [<%= cat.name %>] không? Việc này có thể ảnh hưởng đến các quán ăn đang dùng danh mục này.');">
                                    <button type="submit" class="p-2 text-rose-500 hover:text-rose-700 bg-rose-50 hover:bg-rose-100 dark:bg-rose-900/20 dark:hover:bg-rose-900/40 rounded-lg transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100" title="Xóa danh mục">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </li>
                        <% } %>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>