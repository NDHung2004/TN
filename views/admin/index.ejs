<% layout('layouts/boilerplate') %>

<div class="flex min-h-screen bg-gray-50 dark:bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden md:block sticky top-0 h-screen">
        <%- include('../partials/adminSidebar') %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-6 md:p-10 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight" data-aos="fade-right">Dashboard Tổng Quan</h1>
            
            <!-- Time Filter -->
            <div class="bg-white dark:bg-dark-card rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-1 flex">
                <a href="?period=30d" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= period === '30d' ? 'bg-primary-500 text-white shadow' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800' %>">30 Ngày</a>
                <a href="?period=3m" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= period === '3m' ? 'bg-primary-500 text-white shadow' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800' %>">3 Tháng</a>
                <a href="?period=6m" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= period === '6m' ? 'bg-primary-500 text-white shadow' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800' %>">6 Tháng</a>
                <a href="?period=1y" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= period === '1y' ? 'bg-primary-500 text-white shadow' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800' %>">1 Năm</a>
            </div>
        </div>

        <!-- 1. Overview KPIs -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6 mb-10">
            <!-- Total Users -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Người dùng</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-gray-900 dark:text-white"><%= userCount.toLocaleString() %></h3>
                    <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>

            <!-- Total Restaurants -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Quán ăn</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-gray-900 dark:text-white"><%= campCount.toLocaleString() %></h3>
                    <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                        <i class="fas fa-store"></i>
                    </div>
                </div>
            </div>

            <!-- Total Reviews -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Đánh giá</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-gray-900 dark:text-white"><%= reviewCount.toLocaleString() %></h3>
                    <div class="w-10 h-10 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400">
                        <i class="fas fa-comments"></i>
                    </div>
                </div>
            </div>

            <!-- Avg Rating -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Rating TB</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-gray-900 dark:text-white"><%= avgRating %><span class="text-lg text-yellow-500">★</span></h3>
                    <div class="w-10 h-10 rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center text-yellow-600 dark:text-yellow-400">
                        <i class="fas fa-star"></i>
                    </div>
                </div>
            </div>

            <!-- Reviews Today -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Đánh giá hôm nay</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-gray-900 dark:text-white"><%= reviewsToday.toLocaleString() %></h3>
                    <div class="w-10 h-10 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-600 dark:text-purple-400">
                        <i class="fas fa-calendar-day"></i>
                    </div>
                </div>
            </div>

            <!-- Toxic Reviews -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-5">
                <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Review Độc hại</p>
                <div class="flex items-end justify-between">
                    <h3 class="text-3xl font-extrabold text-red-600"><%= toxicReviewsCount.toLocaleString() %></h3>
                    <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-400">
                        <i class="fas fa-biohazard"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Growth Chart -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 mb-8 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-chart-line mr-2 text-primary-500"></i> Biểu đồ Tăng trưởng</h6>
            </div>
            <div class="p-6 h-[400px]">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- 3. Rating Distribution -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                    <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-star-half-alt mr-2 text-yellow-500"></i> Phân bổ Sao Đánh giá</h6>
                </div>
                <div class="p-6 flex-1 min-h-[300px]">
                    <canvas id="ratingChart"></canvas>
                </div>
            </div>

            <!-- 4. AI Moderation -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <!-- AI Sentiment -->
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                        <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-brain mr-2 text-purple-500"></i> Cảm xúc người dùng</h6>
                    </div>
                    <div class="p-6 flex-1 min-h-[250px]">
                        <canvas id="aiSentimentChart"></canvas>
                    </div>
                </div>

                <!-- AI Toxic -->
                <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                        <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-shield-alt mr-2 text-red-500"></i> Kiểm duyệt Độc hại</h6>
                    </div>
                    <div class="p-6 flex-1 min-h-[250px]">
                        <canvas id="aiToxicChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- 5. Top Restaurants -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                    <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-trophy mr-2 text-yellow-500"></i> Top Địa điểm Nổi bật</h6>
                </div>
                <div class="p-0 flex-1 overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800/50 uppercase">
                            <tr>
                                <th class="px-6 py-4">Tên Quán</th>
                                <th class="px-6 py-4 text-center">Đánh giá</th>
                                <th class="px-6 py-4 text-center">Lượt xem</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% topRestaurants.forEach((camp, idx) => { %>
                                <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors">
                                    <td class="px-6 py-4 font-semibold text-gray-900 dark:text-white flex items-center gap-3">
                                        <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold <%= idx === 0 ? 'bg-yellow-100 text-yellow-600' : idx === 1 ? 'bg-gray-200 text-gray-600' : idx === 2 ? 'bg-amber-100 text-amber-700' : 'bg-primary-50 text-primary-600' %>">
                                            <%= idx + 1 %>
                                        </span>
                                        <a href="/restaurants/<%= camp._id %>" target="_blank" class="hover:text-primary-500"><%= camp.title %></a>
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2.5 py-1 rounded dark:bg-blue-900 dark:text-blue-300">
                                            <%= camp.reviews ? camp.reviews.length : 0 %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">
                                        <%= camp.views.toLocaleString() %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Category Chart -->
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                    <h6 class="font-bold text-gray-800 dark:text-gray-200"><i class="fas fa-tags mr-2 text-primary-500"></i> Phân bổ Danh mục</h6>
                </div>
                <div class="p-6 flex-1 min-h-[300px]">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // System color variables (for Tailwind compatibility)
    const isDarkMode = document.documentElement.classList.contains('dark');
    const textColor = isDarkMode ? '#9ca3af' : '#4b5563';
    const gridColor = isDarkMode ? '#374151' : '#f3f4f6';

    Chart.defaults.color = textColor;
    Chart.defaults.font.family = 'Inter, sans-serif';

    // --- BIỂU ĐỒ 2: TĂNG TRƯỞNG (LINE CHART) ---
    const growthDataRaw = <%- chartGrowthData %>;
    const ctxGrowth = document.getElementById('growthChart').getContext('2d');
    new Chart(ctxGrowth, {
        type: 'line',
        data: {
            labels: growthDataRaw.labels,
            datasets: [
                {
                    label: 'Người dùng mới',
                    data: growthDataRaw.users, 
                    borderColor: '#3b82f6', // blue-500
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'Quán ăn mới',
                    data: growthDataRaw.camps, 
                    borderColor: '#10b981', // emerald-500
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'Đánh giá mới',
                    data: growthDataRaw.reviews, 
                    borderColor: '#f59e0b', // amber-500
                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'top', labels: { usePointStyle: true } }
            },
            scales: {
                x: { grid: { display: false } },
                y: { beginAtZero: true, grid: { color: gridColor, borderDash: [5, 5] }, ticks: { precision: 0 } }
            }
        }
    });

    // --- BIỂU ĐỒ 3: RATING DISTRIBUTION (BAR CHART) ---
    const ratingDataRaw = <%- ratingData %>;
    const ctxRating = document.getElementById('ratingChart').getContext('2d');
    new Chart(ctxRating, {
        type: 'bar',
        data: {
            labels: ['5 Sao', '4 Sao', '3 Sao', '2 Sao', '1 Sao'],
            datasets: [{
                label: 'Số lượng',
                data: ratingDataRaw,
                backgroundColor: [
                    '#10b981', // 5 star - green
                    '#34d399', // 4 star - light green
                    '#fbbf24', // 3 star - yellow
                    '#f87171', // 2 star - light red
                    '#ef4444'  // 1 star - red
                ],
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y', // Biểu đồ cột ngang
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, grid: { color: gridColor, borderDash: [5, 5] }, ticks: { precision: 0 } },
                y: { grid: { display: false } }
            }
        }
    });

    // --- BIỂU ĐỒ 4.1: AI SENTIMENT (DOUGHNUT) ---
    const sentimentDataRaw = <%- aiSentimentData %>;
    const ctxSentiment = document.getElementById('aiSentimentChart').getContext('2d');
    new Chart(ctxSentiment, {
        type: 'doughnut',
        data: {
            labels: ['Tích cực', 'Trung tính', 'Tiêu cực'],
            datasets: [{
                data: sentimentDataRaw,
                backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15 } } }
        }
    });

    // --- BIỂU ĐỒ 4.2: AI TOXIC (PIE) ---
    const toxicDataRaw = <%- toxicData %>;
    const ctxToxic = document.getElementById('aiToxicChart').getContext('2d');
    new Chart(ctxToxic, {
        type: 'pie',
        data: {
            labels: ['Sạch (Clean)', 'Độc hại (Toxic/Spam)'],
            datasets: [{
                data: toxicDataRaw,
                backgroundColor: ['#3b82f6', '#ef4444'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15 } } }
        }
    });

    // --- CATEGORY CHART (DOUGHNUT/BAR) ---
    const ctxCategory = document.getElementById('categoryChart').getContext('2d');
    new Chart(ctxCategory, {
        type: 'bar',
        data: {
            labels: <%- catLabels %>,
            datasets: [{
                label: 'Số lượng',
                data: <%- catData %>,
                backgroundColor: '#8b5cf6',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { beginAtZero: true, grid: { color: gridColor, borderDash: [5, 5] }, ticks: { precision: 0 } }
            }
        }
    });
</script>