<% layout('layouts/boilerplate') %>

<div class="flex min-h-screen bg-gray-50 dark:bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden md:block sticky top-0 h-screen">
        <%- include('../partials/adminSidebar') %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-6 md:p-10 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight" data-aos="fade-right">Quản lý Đánh giá & Bình luận</h1>
            <button type="button" id="btnExportExcel" class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-xl shadow-sm transition-colors" data-aos="fade-left">
                <i class="fas fa-file-excel mr-2"></i> Xuất Excel
            </button>
        </div>

        <!-- Tabs -->
        <div class="border-b border-gray-200 dark:border-gray-800 mb-6" data-aos="fade-up" data-aos-delay="0">
            <nav class="-mb-px flex space-x-6 overflow-x-auto custom-scrollbar">
                <a href="/admin/reviews" class="<%= !filter ? 'border-primary-500 text-primary-600 dark:text-primary-400' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors">
                    Tất cả
                </a>
                <a href="/admin/reviews?filter=reported" class="<%= filter === 'reported' ? 'border-primary-500 text-primary-600 dark:text-primary-400' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors flex items-center">
                    Bị báo cáo 
                    <span class="ml-2 bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400 py-0.5 px-2 rounded-full text-xs">!</span>
                </a>
            </nav>
        </div>

        <!-- Card Container -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
                    <thead class="bg-gray-50 dark:bg-gray-800/50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-5/12">Nội dung</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Đánh giá</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Người đăng</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trạng thái</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                        <% for(let review of reviews) { %>
                            <tr class="transition-colors <%= review.isReported ? 'bg-amber-50/50 hover:bg-amber-50 dark:bg-amber-900/10 dark:hover:bg-amber-900/20' : 'bg-white hover:bg-gray-50 dark:bg-dark-card dark:hover:bg-gray-800/50' %>">
                                
                                <!-- Content -->
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-900 dark:text-gray-300 whitespace-pre-wrap break-words line-clamp-3"><%= review.body %></div>
                                    <div class="text-xs text-gray-400 dark:text-gray-500 mt-1 font-mono">ID: <%= review._id %></div>
                                </td>

                                <!-- Rating -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center text-amber-500 dark:text-amber-400 font-bold text-sm">
                                        <%= review.rating %> <i class="fas fa-star ml-1 text-xs"></i>
                                    </div>
                                </td>

                                <!-- Author -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="h-6 w-6 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-600 dark:text-gray-300 mr-2">
                                            <%= review.author ? review.author.username[0].toUpperCase() : '?' %>
                                        </div>
                                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= review.author ? review.author.username : 'Unknown' %></span>
                                    </div>
                                </td>

                                <!-- Status -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if(review.isReported) { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400">
                                            <i class="fas fa-flag mr-1"></i> Bị báo cáo
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400">
                                            <i class="fas fa-check mr-1"></i> Bình thường
                                        </span>
                                    <% } %>
                                </td>

                                <!-- Actions -->
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex items-center justify-end gap-2">
                                        <% if(review.isReported) { %>
                                            <form action="/admin/reviews/<%= review._id %>/dismiss?_method=PATCH" method="POST" class="inline-block">
                                                <button type="submit" class="p-2 text-emerald-600 hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300 bg-emerald-50 hover:bg-emerald-100 dark:bg-emerald-900/30 dark:hover:bg-emerald-900/50 rounded-lg transition-colors" title="Bỏ qua báo cáo (Giữ lại)">
                                                    <i class="fas fa-shield-alt"></i>
                                                </button>
                                            </form>
                                        <% } %>

                                        <form action="/admin/reviews/<%= review._id %>?_method=DELETE" method="POST" class="inline-block" onsubmit="return confirm('Bạn chắc chắn muốn xóa vĩnh viễn bình luận này?');">
                                            <button type="submit" class="p-2 text-rose-600 hover:text-rose-900 dark:text-rose-400 dark:hover:text-rose-300 bg-rose-50 hover:bg-rose-100 dark:bg-rose-900/30 dark:hover:bg-rose-900/50 rounded-lg transition-colors" title="Xóa bình luận">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% } %>

                        <% if(reviews.length === 0) { %>
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-500 dark:text-gray-400 bg-white dark:bg-dark-card">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fas fa-check-circle text-4xl mb-3 text-emerald-400 dark:text-emerald-500/50"></i>
                                        <p>Không có bình luận nào ở đây cả.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="mt-6 flex justify-center" data-aos="fade-up" data-aos-delay="200">
                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <!-- Nút Previous -->
                    <a href="/admin/reviews?page=<%= currentPage > 1 ? currentPage - 1 : 1 %><%= filter ? '&filter=' + filter : '' %>" 
                       class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed pointer-events-none' : '' %>">
                        <span class="sr-only">Previous</span>
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    <!-- Các số trang -->
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <% if(i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                            <a href="/admin/reviews?page=<%= i %><%= filter ? '&filter=' + filter : '' %>" 
                               aria-current="page" 
                               class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium <%= i === currentPage ? 'z-10 bg-primary-50 dark:bg-primary-900/30 border-primary-500 text-primary-600 dark:text-primary-400' : 'bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                                <%= i %>
                            </a>
                        <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-400">
                                ...
                            </span>
                        <% } %>
                    <% } %>

                    <!-- Nút Next -->
                    <a href="/admin/reviews?page=<%= currentPage < totalPages ? currentPage + 1 : totalPages %><%= filter ? '&filter=' + filter : '' %>" 
                       class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed pointer-events-none' : '' %>">
                        <span class="sr-only">Next</span>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </nav>
            </div>
        <% } %>
        <!-- Thêm đoạn script xuất Excel vào cuối -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.getElementById('btnExportExcel').addEventListener('click', () => {
                Swal.fire({
                    title: 'Tùy chọn Xuất Excel',
                    customClass: {
                        popup: 'rounded-3xl shadow-2xl border border-gray-100 dark:border-gray-800 dark:bg-gray-900',
                        title: 'text-2xl font-extrabold text-gray-900 dark:text-white pt-4',
                        confirmButton: 'px-6 py-2.5 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 transition-colors shadow-sm',
                        cancelButton: 'px-6 py-2.5 bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 font-medium rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors ml-3'
                    },
                    buttonsStyling: false,
                    html: `
                        <div class="text-left mt-4 px-2">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Trạng thái báo cáo</label>
                            <select id="swal-reported" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none mb-5 transition-colors">
                                <option value="all">Tất cả</option>
                                <option value="reported">Bị báo cáo</option>
                                <option value="normal">Bình thường</option>
                            </select>

                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Cảm xúc (AI)</label>
                            <select id="swal-sentiment" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none mb-5 transition-colors">
                                <option value="all">Tất cả</option>
                                <option value="positive">Tích cực</option>
                                <option value="neutral">Trung lập</option>
                                <option value="negative">Tiêu cực</option>
                            </select>

                            <div class="flex gap-4">
                                <div class="w-1/2">
                                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Từ trang</label>
                                    <input id="swal-page-from" type="number" min="1" value="1" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="1">
                                </div>
                                <div class="w-1/2">
                                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Đến trang</label>
                                    <input id="swal-page-to" type="number" min="1" class="block w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="Tất cả">
                                </div>
                            </div>
                        </div>
                    `,
                    focusConfirm: false,
                    showCancelButton: true,
                    confirmButtonText: '<i class="fas fa-file-download mr-1"></i> Tải xuống',
                    cancelButtonText: 'Hủy',
                    preConfirm: () => {
                        return {
                            reported: document.getElementById('swal-reported').value,
                            sentiment: document.getElementById('swal-sentiment').value,
                            pageFrom: document.getElementById('swal-page-from').value,
                            pageTo: document.getElementById('swal-page-to').value
                        }
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        const v = result.value;
                        let url = '/admin/reviews/export?reported=' + v.reported + '&sentiment=' + v.sentiment;
                        if(v.pageFrom) url += '&pageFrom=' + v.pageFrom;
                        if(v.pageTo) url += '&pageTo=' + v.pageTo;
                        window.location.href = url;
                    }
                });
            });
        </script>
    </div>
</div>