<% layout('layouts/boilerplate') %>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 p-0">
            <%- include('../partials/adminSidebar') %>
        </div>

        <div class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Quản lý Người dùng</h1>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form action="/admin/users" method="GET" class="d-flex gap-2">
                        <input class="form-control" type="text" name="search" placeholder="Tìm theo tên hoặc email..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i> Tìm</button>
                        <% if(typeof search !== 'undefined' && search) { %>
                            <a href="/admin/users" class="btn btn-secondary">Xóa lọc</a>
                        <% } %>
                    </form>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Avatar</th>
                                    <th>Thông tin</th>
                                    <th>Ngày tham gia</th>
                                    <th>Vai trò</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                                <tbody>
                                    <% for(let user of users) { %>
                                    <tr id="user-row-<%= user._id %>">
                                        
                                        <td>
                                            <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center" 
                                                style="width: 40px; height: 40px; font-weight: bold;">
                                                <%= user.username[0].toUpperCase() %>
                                            </div>
                                        </td>

                                        <td>
                                            <strong><%= user.username %></strong><br>
                                            <small class="text-muted"><%= user.email %></small>
                                        </td>

                                        <td><%= user.createdAt ? user.createdAt.toLocaleDateString('vi-VN') : 'N/A' %></td>

                                        <td>
                                            <% if(user.role === 'admin') { %>
                                                <span class="badge bg-danger">Admin</span>
                                            <% } else if(user.role === 'moderator') { %>
                                                <span class="badge bg-warning text-dark">Moderator</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">User</span>
                                            <% } %>
                                        </td>

                                        <td>
                                            <% if(user.isBanned) { %>
                                                <span class="badge bg-danger">Đã khóa</span>
                                            <% } else { %>
                                                <span class="badge bg-success">Hoạt động</span>
                                            <% } %>
                                        </td>

                                        <td>
                                            <div class="d-flex gap-2">
                                                <a href="/admin/users/<%= user._id %>/edit" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>

                                                <% if(!user._id.equals(currentUser._id)) { %>
                                                    <form action="/admin/users/<%= user._id %>/ban?_method=PATCH&page=<%= typeof currentPage !== 'undefined' ? currentPage : 1 %><%= typeof search !== 'undefined' && search ? `&search=${search}` : '' %>" method="POST">
                                                        <% if(user.isBanned) { %>
                                                            <button class="btn btn-sm btn-outline-success">
                                                                <i class="fas fa-unlock"></i> Mở
                                                            </button>
                                                        <% } else { %>
                                                            <button class="btn btn-sm btn-outline-danger">
                                                                <i class="fas fa-lock"></i> Khóa
                                                            </button>
                                                        <% } %>
                                                    </form>
                                                <% } else { %>
                                                    <span class="text-muted small">Chính bạn</span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>
                                </tbody>
                        </table>
                        
                    </div>
                    <% if (totalPages > 1) { %>
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    
                    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/users?page=<%= currentPage - 1 %><%= search ? `&search=${search}` : '' %>">Trước</a>
                    </li>

                    <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link" href="/admin/users?page=<%= i %><%= search ? `&search=${search}` : '' %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>

                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/users?page=<%= currentPage + 1 %><%= search ? `&search=${search}` : '' %>">Sau</a>
                    </li>
                </ul>
            </nav>
            <% } %>
                </div>
            </div>
        </div>
    </div>
</div>