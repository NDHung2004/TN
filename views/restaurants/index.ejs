<% layout("/layouts/boilerplate") %>

    <!-- Header Section -->
    <div class="mb-10 text-center" data-aos="fade-down">
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-4">Khám phá Quán Ăn</h1>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">Tìm kiếm những địa điểm ẩm thực tuyệt vời
            nhất được đánh giá bởi cộng đồng.</p>
    </div>

    <!-- Map Section -->
    <div class="mb-12 rounded-2xl overflow-hidden shadow-lg border border-gray-100 dark:border-gray-800"
        data-aos="fade-up">
        <div id="cluster-map" class="w-full h-[250px] md:h-[350px]"></div>
    </div>

    <!-- Search and Action Bar -->
    <div class="relative z-[100] bg-white dark:bg-dark-card p-4 sm:p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 mb-10 flex flex-col md:flex-row gap-4 justify-between items-center"
        data-aos="fade-up" data-aos-delay="100">
        <div class="w-full">
            <form action="/restaurants" method="GET" class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i class="fas fa-search text-gray-400"></i>
                </div>
                <input type="text" name="search" id="searchInput" autocomplete="off"
                    class="block w-full pl-10 pr-3 py-3 border border-gray-200 dark:border-gray-700 rounded-xl leading-5 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors sm:text-sm"
                    placeholder="Tìm tên quán, địa điểm, món ăn, người dùng..." value="<%= search %>">

                <!-- Autocomplete Dropdown -->
                <div id="autocompleteDropdown"
                    class="hidden absolute top-full left-0 mt-1 w-full bg-white dark:bg-dark-card border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg z-[100] overflow-hidden p-3">
                    <ul id="autocompleteList"
                        class="flex flex-wrap gap-2">
                        <!-- Danh sách gợi ý sẽ được chèn vào đây -->
                    </ul>
                </div>
                <div class="absolute inset-y-0 right-0 flex items-center">
                    <% if(search || typeof lat !=='undefined' ) { %>
                        <a href="/restaurants" class="p-2 mr-1 text-gray-400 hover:text-red-500 transition-colors"
                            title="Xóa lọc">
                            <i class="fas fa-times"></i>
                        </a>
                        <% } %>
                            <button type="submit"
                                class="h-full px-8 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-r-xl transition-colors border border-transparent focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                                Tìm kiếm
                            </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Nearby Filters (Only show if searching nearby) -->
    <% if (typeof lat !=='undefined' && lat && typeof lng !=='undefined' && lng) { %>
        <div class="mb-8 flex justify-center" data-aos="fade-up" data-aos-delay="150">
            <div class="inline-flex bg-gray-100 dark:bg-gray-800 p-1 rounded-xl shadow-sm">
                <a href="/restaurants?lat=<%= lat.replace('.', '_') %>&lng=<%= lng.replace('.', '_') %>&distance=50&sort=nearest"
                    class="px-5 py-2.5 rounded-lg text-sm font-bold transition-all duration-300 <%= sortMode === 'nearest' ? 'bg-white dark:bg-dark-card text-primary-600 dark:text-primary-400 shadow-sm' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white' %>">
                    <i class="fas fa-map-marker-alt mr-1.5"></i> Gần nhất
                </a>
                <a href="/restaurants?lat=<%= lat.replace('.', '_') %>&lng=<%= lng.replace('.', '_') %>&distance=50&sort=hot"
                    class="px-5 py-2.5 rounded-lg text-sm font-bold transition-all duration-300 <%= sortMode === 'hot' ? 'bg-white dark:bg-dark-card text-rose-600 dark:text-rose-400 shadow-sm' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white' %>">
                    <i class="fas fa-fire mr-1.5"></i> Hot
                </a>
                <a href="/restaurants?lat=<%= lat.replace('.', '_') %>&lng=<%= lng.replace('.', '_') %>&distance=50&sort=best"
                    class="px-5 py-2.5 rounded-lg text-sm font-bold transition-all duration-300 <%= sortMode === 'best' ? 'bg-white dark:bg-dark-card text-emerald-600 dark:text-emerald-400 shadow-sm' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white' %>">
                    <i class="fas fa-star mr-1.5"></i> Tốt nhất
                </a>
            </div>
        </div>
        <% } %>

            <!-- BẮT ĐẦU: KHU VỰC GỢI Ý CÁ NHÂN HÓA -->
            <% if (typeof recommendedRestaurants !=='undefined' && recommendedRestaurants &&
                recommendedRestaurants.length> 0) { %>
                <div class="mb-12" data-aos="fade-up">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 bg-rose-100 dark:bg-rose-900/30 rounded-lg text-rose-600 dark:text-rose-400">
                            <i class="fas fa-magic text-xl"></i>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Dành riêng cho bạn</h2>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <% for (let i=0; i < recommendedRestaurants.length; i++) { %>
                            <% let restaurant=recommendedRestaurants[i]; %>
                                <div class="bg-white dark:bg-dark-card rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-rose-200 dark:border-rose-900/50 transition-all duration-300 group flex flex-col h-full relative"
                                    data-aos="fade-up" data-aos-delay="<%= (i % 4) * 50 %>">
                                    <!-- Badge Gợi ý -->
                                    <div
                                        class="absolute top-0 right-0 bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg z-10 shadow-md">
                                        Mức độ phù hợp: <%= Math.round(restaurant.recommendationScore) %>
                                    </div>

                                    <!-- Image Container -->
                                    <div class="relative h-48 overflow-hidden">
                                        <% if (restaurant.images && restaurant.images.length) { %>
                                            <img src="<%=restaurant.images[0].url %>" alt="<%= restaurant.title %>"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                            <% } else { %>
                                                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=1200&auto=format&fit=crop"
                                                    alt="Vietnamese food"
                                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                                <% } %>
                                                    <div
                                                        class="absolute top-3 left-3 bg-white/90 dark:bg-black/70 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-primary-600 dark:text-primary-400 shadow-sm flex items-center gap-1">
                                                        <i class="fas fa-tag text-[10px]"></i>
                                                        <%= restaurant.category || 'Ẩm thực' %>
                                                    </div>
                                    </div>

                                    <!-- Content Container -->
                                    <div class="p-4 flex flex-col flex-grow">
                                        <h3
                                            class="text-lg font-bold text-gray-900 dark:text-white line-clamp-1 mb-1 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                                            <%= restaurant.title %>
                                        </h3>

                                        <p
                                            class="text-sm text-gray-500 dark:text-gray-400 flex items-start gap-1.5 mb-3 line-clamp-1">
                                            <i class="fas fa-map-marker-alt mt-1 text-gray-400 shrink-0"></i>
                                            <span>
                                                <%= restaurant.location %>
                                            </span>
                                        </p>

                                        <!-- Statistics Badges -->
                                        <div class="flex flex-wrap gap-2 mb-3">
                                            <span
                                                class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-yellow-50 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400"
                                                title="Đánh giá trung bình">
                                                <i class="fas fa-star mr-1 text-yellow-500"></i>
                                                <%= restaurant.avgRating ? restaurant.avgRating.toFixed(1) : 'Chưa có'
                                                    %>
                                            </span>
                                            <% if (restaurant.positiveRatio !==undefined && restaurant.reviewCount> 0) {
                                                %>
                                                <span
                                                    class="inline-flex items-center px-2 py-1 rounded text-xs font-medium <%= restaurant.positiveRatio >= 50 ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>"
                                                    title="Tỉ lệ tích cực">
                                                    <i
                                                        class="fas <%= restaurant.positiveRatio >= 50 ? 'fa-thumbs-up text-emerald-500' : 'fa-thumbs-down text-rose-500' %> mr-1"></i>
                                                    <%= Math.round(restaurant.positiveRatio) %>%
                                                </span>
                                                <% } %>
                                        </div>

                                        <div class="mt-auto pt-3 border-t border-gray-100 dark:border-gray-800">
                                            <a href="/restaurants/<%= restaurant._id %>"
                                                class="block w-full py-2 px-4 text-center text-sm font-medium text-rose-600 dark:text-rose-400 bg-rose-50 dark:bg-rose-900/20 rounded-xl hover:bg-rose-100 dark:hover:bg-rose-900/40 transition-colors">
                                                Khám phá ngay
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                    </div>
                </div>

                <!-- Đường ngăn cách -->
                <div class="flex items-center justify-center gap-4 mb-8" data-aos="fade-up">
                    <div class="h-px bg-gray-200 dark:bg-gray-700 w-16 md:w-32"></div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white text-center">Tất cả quán ăn</h2>
                    <div class="h-px bg-gray-200 dark:bg-gray-700 w-16 md:w-32"></div>
                </div>
                <% } %>
                    <!-- KẾT THÚC: KHU VỰC GỢI Ý -->

                    <!-- HIỂN THỊ NGƯỜI DÙNG TÌM ĐƯỢC -->
                    <% if (typeof matchedUsers !=='undefined' && matchedUsers.length> 0) { %>
                        <div class="mb-8" data-aos="fade-up">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center">
                                <i class="fas fa-users mr-2 text-primary-500"></i> Người dùng
                            </h3>
                            <div class="flex flex-wrap gap-3">
                                <% for (let user of matchedUsers) { %>
                                    <a href="/profile/<%= user._id %>"
                                        class="flex items-center p-2 pr-4 bg-white dark:bg-dark-card border border-gray-100 dark:border-gray-800 rounded-full hover:shadow-md hover:border-primary-500 dark:hover:border-primary-500 transition-all duration-300 group">
                                        <div
                                            class="relative w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-bold text-sm mr-2 shadow-sm overflow-hidden flex-shrink-0">
                                            <span class="z-0">
                                                <%= user.username[0].toUpperCase() %>
                                            </span>
                                            <% if(user.avatar && user.avatar.url &&
                                                !user.avatar.url.includes('default-avatar')) { %>
                                                <img src="<%= user.avatar.url %>" alt="<%= user.username %>"
                                                    class="w-full h-full object-cover absolute inset-0 z-10"
                                                    onerror="this.style.display='none'" />
                                                <% } %>
                                        </div>
                                        <div class="flex items-center">
                                            <div class="text-sm font-bold text-gray-900 dark:text-white truncate max-w-[120px]">
                                                <%= user.username %>
                                            </div>
                                            <% if(user.isVerified) { %>
                                                <div class="ml-1 flex-shrink-0">
                                                    <%- include('../partials/verifiedBadge') %>
                                                </div>
                                            <% } %>
                                            <div class="text-xs text-gray-500 dark:text-gray-400 ml-2 whitespace-nowrap">
                                                • <%= user.followersCount || 0 %> người theo dõi
                                            </div>
                                        </div>
                                    </a>
                                    <% } %>
                            </div>
                        </div>
                        <% } %>

                            <!-- Restaurants Grid -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
                                <% for (let i=0; i < restaurants.length; i++) { %>
                                    <% let restaurant=restaurants[i]; %>
                                        <div class="bg-white dark:bg-dark-card rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100 dark:border-gray-800 transition-all duration-300 group flex flex-col h-full"
                                            data-aos="fade-up" data-aos-delay="<%= (i % 4) * 50 %>">

                                            <!-- Image Container -->
                                            <div class="relative h-56 overflow-hidden">
                                                <% if (restaurant.images.length) { %>
                                                    <img src="<%=restaurant.images[0].url %>"
                                                        alt="<%= restaurant.title %>"
                                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                                    <% } else { %>
                                                        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=1200&auto=format&fit=crop"
                                                            alt="Vietnamese food"
                                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                                        <% } %>
                                                            <div
                                                                class="absolute top-3 left-3 bg-white/90 dark:bg-black/70 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-primary-600 dark:text-primary-400 shadow-sm flex items-center gap-1">
                                                                <i class="fas fa-tag text-[10px]"></i>
                                                                <%= restaurant.category || 'Ẩm thực' %>
                                                            </div>
                                            </div>

                                            <!-- Content Container -->
                                            <div class="p-5 flex flex-col flex-grow">
                                                <h3
                                                    class="text-lg font-bold text-gray-900 dark:text-white line-clamp-1 mb-1 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                                                    <%= restaurant.title %>
                                                </h3>

                                                <p
                                                    class="text-sm text-gray-500 dark:text-gray-400 flex items-start gap-1.5 mb-3 line-clamp-1">
                                                    <i class="fas fa-map-marker-alt mt-1 text-gray-400 shrink-0"></i>
                                                    <span>
                                                        <%= restaurant.location %>
                                                    </span>
                                                    <% if (restaurant.dist && restaurant.dist.calculated) { %>
                                                        <span class="text-gray-400 mx-1">•</span>
                                                        <span
                                                            class="text-blue-600 dark:text-blue-400 font-medium whitespace-nowrap">
                                                            <%= (restaurant.dist.calculated / 1000).toFixed(1) %> km
                                                        </span>
                                                        <% } %>
                                                </p>

                                                <p
                                                    class="text-sm text-gray-600 dark:text-gray-300 line-clamp-2 mb-3 flex-grow">
                                                    <%= restaurant.description %>
                                                </p>

                                                <!-- Statistics Badges -->
                                                <div class="flex flex-wrap gap-2 mb-4">
                                                    <span
                                                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300"
                                                        title="Lượt truy cập">
                                                        <i class="fas fa-eye mr-1 text-gray-500"></i>
                                                        <%= restaurant.views || 0 %>
                                                    </span>

                                                    <span
                                                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-yellow-50 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400"
                                                        title="Đánh giá trung bình">
                                                        <i class="fas fa-star mr-1 text-yellow-500"></i>
                                                        <%= restaurant.avgRating ? restaurant.avgRating.toFixed(1)
                                                            : 'Chưa có' %>
                                                            <% if(restaurant.reviewCount) { %> <span
                                                                    class="ml-1 text-yellow-600/70 dark:text-yellow-500/70">(
                                                                    <%= restaurant.reviewCount %>)</span>
                                                                <% } %>
                                                    </span>
                                                    <% if (restaurant.positiveRatio !==undefined &&
                                                        restaurant.reviewCount> 0) {
                                                        %>
                                                        <span
                                                            class="inline-flex items-center px-2 py-1 rounded text-xs font-medium <%= restaurant.positiveRatio >= 50 ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>"
                                                            title="Tỉ lệ tích cực">
                                                            <i
                                                                class="fas <%= restaurant.positiveRatio >= 50 ? 'fa-thumbs-up text-emerald-500' : 'fa-thumbs-down text-rose-500' %> mr-1"></i>
                                                            <%= Math.round(restaurant.positiveRatio) %>%
                                                        </span>
                                                        <% } %>
                                                </div>

                                                <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-800">
                                                    <a href="/restaurants/<%= restaurant._id %>"
                                                        class="block w-full py-2.5 px-4 text-center text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 rounded-xl hover:bg-primary-100 dark:hover:bg-primary-900/40 transition-colors">
                                                        Xem chi tiết
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <% } %>
                            </div>

                            <!-- Empty State -->
                            <% if (restaurants.length===0) { %>
                                <div class="text-center py-20 bg-white dark:bg-dark-card rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm"
                                    data-aos="fade-up">
                                    <div
                                        class="w-20 h-20 mx-auto bg-gray-50 dark:bg-gray-800 rounded-full flex items-center justify-center mb-4">
                                        <i class="fas fa-search text-3xl text-gray-400"></i>
                                    </div>
                                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Không tìm thấy
                                        kết quả
                                    </h3>
                                    <p class="text-gray-500 dark:text-gray-400 max-w-sm mx-auto mb-6">Chúng tôi không
                                        tìm thấy
                                        quán ăn nào khớp với tìm kiếm của bạn. Hãy thử từ khóa khác.</p>
                                    <a href="/restaurants"
                                        class="inline-flex items-center text-primary-600 dark:text-primary-400 hover:underline">
                                        <i class="fas fa-arrow-left mr-2"></i> Quay lại tất cả quán ăn
                                    </a>
                                </div>
                                <% } %>

                                    <!-- Pagination -->
                                    <% if (totalPages> 1) { %>
                                        <div class="flex justify-center mt-8 mb-16" data-aos="fade-up">
                                            <nav class="inline-flex rounded-xl shadow-sm bg-white dark:bg-dark-card border border-gray-200 dark:border-gray-700 p-1"
                                                aria-label="Pagination">

                                                <a href="<%= currentPage == 1 ? '#' : '/restaurants?page=' + (currentPage - 1) + (search ? '&search=' + search : '') %>"
                                                    class="relative inline-flex items-center px-3 py-2 text-sm font-medium rounded-lg <%= currentPage == 1 ? 'text-gray-400 cursor-not-allowed' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors' %>">
                                                    <i class="fas fa-chevron-left mr-1 text-xs"></i> Trước
                                                </a>

                                                <% let startPage=Math.max(1, currentPage - 2); let
                                                    endPage=Math.min(totalPages, currentPage + 2); %>

                                                    <% if (startPage> 1) { %>
                                                        <a href="/restaurants?page=1<%= search ? '&search=' + search : '' %>"
                                                            class="relative inline-flex items-center px-3.5 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors">1</a>
                                                        <% if (startPage> 2) { %>
                                                            <span
                                                                class="relative inline-flex items-center px-3.5 py-2 text-sm font-medium text-gray-500">...</span>
                                                            <% } %>
                                                                <% } %>

                                                                    <% for(let i=startPage; i <=endPage; i++) { %>
                                                                        <a href="/restaurants?page=<%= i %><%= search ? '&search=' + search : '' %>"
                                                                            class="relative inline-flex items-center px-3.5 py-2 text-sm font-medium rounded-lg transition-colors <%= currentPage === i ? 'z-10 bg-primary-50 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 font-bold' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800' %>">
                                                                            <%= i %>
                                                                        </a>
                                                                        <% } %>

                                                                            <% if (endPage < totalPages) { %>
                                                                                <% if (endPage < totalPages - 1) { %>
                                                                                    <span
                                                                                        class="relative inline-flex items-center px-3.5 py-2 text-sm font-medium text-gray-500">...</span>
                                                                                    <% } %>
                                                                                        <a href="/restaurants?page=<%= totalPages %><%= search ? '&search=' + search : '' %>"
                                                                                            class="relative inline-flex items-center px-3.5 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors">
                                                                                            <%= totalPages %>
                                                                                        </a>
                                                                                        <% } %>

                                                                                            <a href="<%= currentPage == totalPages ? '#' : '/restaurants?page=' + (currentPage + 1) + (search ? '&search=' + search : '') %>"
                                                                                                class="relative inline-flex items-center px-3 py-2 text-sm font-medium rounded-lg <%= currentPage == totalPages ? 'text-gray-400 cursor-not-allowed' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors' %>">
                                                                                                Sau <i
                                                                                                    class="fas fa-chevron-right ml-1 text-xs"></i>
                                                                                            </a>

                                            </nav>
                                        </div>
                                        <% } %>

                                            <script>
                                                const mapToken = "<%-process.env.MAPBOX_TOKEN %>";
                                                const restaurants = { features: <%- JSON.stringify(allRestaurantsForMap) %> };
                                                const userLat = <%= typeof lat !== 'undefined' && lat ? lat : 'null' %>;
                                                const userLng = <%= typeof lng !== 'undefined' && lng ? lng : 'null' %>;
                                            </script>
                                            <script src="/javascript/clustermap.js"></script>

                                            <!-- Javascript cho Autocomplete -->
                                            <script>
                                                const searchInput = document.getElementById('searchInput');
                                                const autocompleteDropdown = document.getElementById('autocompleteDropdown');
                                                const autocompleteList = document.getElementById('autocompleteList');
                                                let debounceTimer;

                                                searchInput.addEventListener('input', function () {
                                                    clearTimeout(debounceTimer);
                                                    const query = this.value.trim();

                                                    if (query.length < 2) {
                                                        autocompleteDropdown.classList.add('hidden');
                                                        return;
                                                    }

                                                    debounceTimer = setTimeout(async () => {
                                                        try {
                                                            const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                                                            const users = await res.json();

                                                            if (users.length > 0) {
                                                                autocompleteList.innerHTML = '';
                                                                users.forEach(user => {
                                                                    const li = document.createElement('li');

                                                                    let verifiedHtml = user.isVerified
                                                                        ? `<svg class="w-3 h-3 inline-block text-blue-500 ml-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>`
                                                                        : '';

                                                                    let avatarHtml = '';
                                                                    if (user.avatar && user.avatar.url && !user.avatar.url.includes('default-avatar')) {
                                                                        avatarHtml = `
                                                                    <div class="relative w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-bold text-xs mr-3 flex-shrink-0 overflow-hidden">
                                                                        <span class="z-0">${user.username.charAt(0).toUpperCase()}</span>
                                                                        <img src="${user.avatar.url}" alt="" class="w-full h-full object-cover absolute inset-0 z-10" onerror="this.style.display='none'" />
                                                                    </div>
                                                                `;
                                                                    } else {
                                                                        avatarHtml = `
                                                                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-bold text-xs mr-3 flex-shrink-0">
                                                                        ${user.username.charAt(0).toUpperCase()}
                                                                    </div>
                                                                `;
                                                                    }

                                                                    li.innerHTML = `
                                                                <a href="/profile/${user._id}" class="flex items-center px-3 py-2 border border-gray-100 dark:border-gray-800 rounded-full hover:border-primary-500 dark:hover:border-primary-500 hover:shadow-sm transition-colors group">
                                                                    ${avatarHtml}
                                                                    <div class="text-sm font-medium text-gray-900 dark:text-white flex items-center">
                                                                        ${user.username}
                                                                        ${verifiedHtml}
                                                                        <span class="text-xs text-gray-500 dark:text-gray-400 ml-2 font-normal">
                                                                            • ${user.followersCount || 0} người theo dõi
                                                                        </span>
                                                                    </div>
                                                                </a>
                                                            `;
                                                                    autocompleteList.appendChild(li);
                                                                });
                                                                autocompleteDropdown.classList.remove('hidden');
                                                            } else {
                                                                autocompleteDropdown.classList.add('hidden');
                                                            }
                                                        } catch (err) {
                                                            console.error("Autocomplete error:", err);
                                                        }
                                                    }, 300); // 300ms debounce
                                                });

                                                // Ẩn dropdown khi click ra ngoài
                                                document.addEventListener('click', function (e) {
                                                    if (!searchInput.contains(e.target) && !autocompleteDropdown.contains(e.target)) {
                                                        autocompleteDropdown.classList.add('hidden');
                                                    }
                                                });
                                            </script>