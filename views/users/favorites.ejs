<% layout('layouts/boilerplate') %>

<div class="container mt-5">
    <h1 class="text-center mb-4 text-danger">Danh sách quán yêu thích <i class="fas fa-heart"></i></h1>
    
    <% if(favorites.length === 0) { %>
        <div class="alert alert-warning text-center">
            Bạn chưa yêu thích quán nào cả. <a href="/campgrounds" class="alert-link">Khám phá ngay!</a>
        </div>
    <% } else { %>
        <div class="row">
            <% for(let camp of favorites) { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <% if(camp.images.length) { %>
                            <img src="<%= camp.images[0].url %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <% } else { %>
                            <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=500&q=60" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <% } %>
                        <div class="card-body">
                            <h5 class="card-title"><%= camp.title %></h5>
                            <p class="card-text text-muted"><%= camp.location %></p>
                            <a href="/campgrounds/<%= camp._id %>" class="btn btn-primary btn-sm">Xem chi tiết</a>
                            
                            <form action="/campgrounds/<%= camp._id %>/favorite" method="POST" class="d-inline float-end">
                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i> Bỏ thích</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>