<% layout('layouts/boilerplate') %>

<div class="container mt-5">
    <h1 class="text-center mb-4">Quản lý quán ăn của tôi</h1>
    
    <% if(myCampgrounds.length === 0) { %>
        <div class="alert alert-info text-center">
            Bạn chưa đăng quán ăn nào. <a href="/campgrounds/new" class="alert-link">Đăng ngay!</a>
        </div>
    <% } else { %>
        
        <div class="row">
            <% for(let camp of myCampgrounds) { %>
                <div class="col-md-12 mb-3">
                    <div class="card shadow-sm">
                        <div class="row g-0">
                            <div class="col-md-3">
                                <% if(camp.images.length) { %>
                                    <img src="<%= camp.images[0].url %>" class="img-fluid rounded-start" style="height: 100%; object-fit: cover;" alt="">
                                <% } else { %>
                                    <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=500&q=60" class="img-fluid rounded-start" alt="">
                                <% } %>
                            </div>
                            
                            <div class="col-md-9">
                                <div class="card-body">
                                    <h5 class="card-title"><%= camp.title %></h5>
                                    <p class="card-text text-muted"><small><%= camp.location %></small></p>
                                    <p class="card-text"><%= camp.description.substring(0, 100) %>...</p>
                                    
                                    <div class="d-flex justify-content-end">
                                        <a href="/campgrounds/<%= camp._id %>" class="btn btn-sm btn-primary me-2">Xem</a>
                                        <a href="/campgrounds/<%= camp._id %>/edit" class="btn btn-sm btn-warning me-2">Sửa</a>
                                        <form action="/campgrounds/<%= camp._id %>?_method=DELETE" method="POST" style="display: inline;">
                                            <button class="btn btn-sm btn-danger">Xóa</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>