<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/stylesheets/stars.css" />

<div class="row mt-4">
  <div class="col-6">
    
    <div id="campgroundCarousel" class="carousel slide">
      <div class="carousel-inner">
        <% campground.images.forEach((img, i) =>{ %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <img src="<%= img.url%>" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="" />
        </div>
        <% }) %>
      </div>

      <% if(campground.images.length > 1) {%>
      <button class="carousel-control-prev" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Trước</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sau</span>
      </button>
      <% } %>
    </div>

    <div class="card mb-3">
      <div class="card-body">
        
        <div class="d-flex justify-content-between align-items-center">
            
            <h5 class="card-title" style="font-size: 1.5rem; font-weight: bold; margin-bottom: 0;">
                <%=campground.title%>
            </h5>
            
            <span class="badge rounded-pill bg-info text-dark mb-2">
            <i class="fas fa-tag small"></i> <%= campground.category || 'Ẩm thực' %>
            </span>
            
            <% if(currentUser) { %>
                <form action="/campgrounds/<%= campground._id %>/favorite" method="POST" class="d-inline">
                    
                    <% if(currentUser.favorites.includes(campground._id)) { %>
                        <button class="btn btn-danger btn-sm fw-bold">
                            ĐÃ THÍCH
                        </button>
                    <% } else { %>
                        <button class="btn btn-outline-danger btn-sm fw-bold">
                            YÊU THÍCH
                        </button>
                    <% } %>

                </form>
            <% } %>
        </div>
        <p class="card-text mt-3"><%=campground.description%></p>
        <% if (aiStats.total > 0) { %>
    <div class="card mb-4 shadow-sm border-0 bg-light">
        <div class="card-body">
            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-robot"></i>Cảm Xúc Khách Hàng</h6>
            
            <div class="d-flex justify-content-between mb-1 small fw-bold">
                <span class="text-success"><%= aiStats.positivePct %>% Hài lòng</span>
                <span class="text-danger"><%= aiStats.negativePct %>% Phàn nàn</span>
            </div>
            
            <div class="progress" style="height: 10px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: <%= aiStats.positivePct %>%"></div>
                <div class="progress-bar bg-danger" role="progressbar" style="width: <%= aiStats.negativePct %>%"></div>
            </div>
            <small class="text-muted mt-2 d-block">Dựa trên <%= aiStats.total %> đánh giá .</small>
        </div>
    </div>
<% } %>
      </div>

      <ul class="list-group list-group-flush">
        <li class="list-group-item text-secondary">
          <%= campground.location%>
        </li>
        <li class="list-group-item text-black">
          Đăng bởi: <strong><%= campground.author.username%></strong>
        </li>
        <li class="list-group-item text-success fw-bold">₫<%=campground.price%>/người</li>
      </ul>

      <% if(currentUser && (campground.author.equals(currentUser) || currentUser.role === 'admin')) { %>
    <div class="card-body">
        <a href="/campgrounds/<%=campground._id%>/edit" class="btn btn-info">Sửa</a>
        <form action="/campgrounds/<%=campground._id%>?_method=DELETE" method="POST" class="d-inline">
            <button class="btn btn-danger">Xóa</button>
        </form>
    </div>
<% } %>
      
      <div class="card-footer text-secondary">Cập nhật 2 ngày trước</div>
    </div>
  </div>

  <div class="col-6">
    <div id="map"></div>

    <% if(currentUser) {%>
    <h2>Để lại đánh giá</h2>
    <form action="/campgrounds/<%=campground._id%>/reviews" method="POST" class="validated-form" novalidate>
      <div class="mb-3">
        <fieldset class="starability-basic">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 sao</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 sao</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 sao</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 sao</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 sao</label>
        </fieldset>
      </div>
      <div class="mb-3">
        <label class="form-label" for="body">Nội dung đánh giá</label>
        <textarea class="form-control" name="review[body]" required id="body"></textarea>
      </div>
      <button class="btn btn-success mb-3">Gửi đánh giá</button>
    </form>
    <h2>Danh sách đánh giá</h2>
    <% } %>

    <% for(let review of campground.reviews) { %>
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="card-subtitle mb-2 text-muted d-flex align-items-center">
                <i class="fas fa-user-circle me-1"></i> <%= review.author.username %>
                
                <% if(review.sentiment === 'positive') { %>
                    <span class="badge bg-success ms-2 rounded-pill"><i class="fas fa-smile"></i> Tích cực</span>
                <% } else if(review.sentiment === 'negative') { %>
                    <span class="badge bg-danger ms-2 rounded-pill"><i class="fas fa-frown"></i> Tiêu cực</span>
                <% } else { %>
                    <span class="badge bg-secondary ms-2 rounded-pill">Trung lập</span>
                <% } %>
            </h6>
            
            <p class="starability-result" data-rating="<%= review.rating %>">Đánh giá: <%= review.rating %> sao</p>
            
            <% if(review.isToxic) { %>
                <div class="alert alert-warning py-2 mb-0" role="alert">
                    <i class="fas fa-exclamation-triangle"></i> Nội dung đã bị ẩn vì vi phạm tiêu chuẩn cộng đồng (chứa ngôn từ thô tục/xúc phạm).
                </div>
            <% } else { %>
                <p class="card-text">Nhận xét: <%= review.body %></p>
            <% } %>
            
            <% if(currentUser && review.author.equals(currentUser._id)) { %>
                <form action="/campgrounds/<%=campground._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST" class="mt-2">
                    <button class="btn btn-sm btn-outline-danger">Xóa bình luận</button>
                </form>
            <% } %>
        </div>
    </div>
<% } %>
  </div>
</div>

<script>
  const mapToken = "<%-process.env.MAPBOX_TOKEN %>";
  const campground = <%- JSON.stringify(campground) %>
</script>
<script src="/javascript/showPageMap.js"></script>